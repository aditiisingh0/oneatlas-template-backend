{
  "name": "@oneatlas/templates",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./types": "./dist/types/index.js",
    "./registry": "./dist/registry/index.js",
    "./loader": "./dist/loader/index.js",
    "./composer": "./dist/composer/index.js",
    "./spec-engine": "./dist/spec-engine/index.js",
    "./preview": "./dist/preview/index.js",
    "./deployment": "./dist/deployment/index.js",
    "./workflows": "./dist/workflows/index.js"
  },
  "scripts": {
    "build": "tsup src/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
    "test": "vitest run",
    "type-check": "tsc --noEmit",
    "test:api": "vitest run src/__tests__/api.test.ts",
    "test:all": "vitest run",
    "test:watch": "vitest",
    "load:smoke": "k6 run src/load-tests/k6-smoke-test.js",
    "load:test": "k6 run src/load-tests/k6-load-test.js",
    "start:api": "node dist/api/server.js"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.0",
    "@sentry/node": "^8.55.2",
    "@types/express": "^5.0.6",
    "@upstash/redis": "^1.31.0",
    "esbuild": "^0.21.0",
    "express": "^5.2.1",
    "prettier": "^3.3.0",
    "ts-morph": "^22.0.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "tsup": "^8.0.0",
    "vitest": "^1.6.0"
  }
}
